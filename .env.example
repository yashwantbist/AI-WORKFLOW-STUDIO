# -- LLM Provider -------------------------------------------------------------
# Replace with your actual API key. Never commit the real value.
LLM_API_KEY=replace_with_your_key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL_NAME=replace_with_model_name

# -- Embedding Model ----------------------------------------------------------
EMBEDDING_API_KEY=replace_with_embedding_key
EMBEDDING_MODEL_NAME=replace_with_embedding_model_name

# -- Database -----------------------------------------------------------------
DATABASE_URL=replace_with_database_url
DATABASE_NAME=replace_with_database_name

# -- Vector Store -------------------------------------------------------------
VECTOR_STORE_URL=replace_with_vector_store_url
VECTOR_STORE_API_KEY=replace_with_vector_store_key

# -- Authentication -----------------------------------------------------------
AUTH_SECRET=replace_with_auth_secret
JWT_EXPIRY_SECONDS=3600

# -- Storage ------------------------------------------------------------------
OBJECT_STORAGE_BUCKET=replace_with_bucket_name
OBJECT_STORAGE_KEY_ID=replace_with_storage_key_id
OBJECT_STORAGE_SECRET=replace_with_storage_secret

# -- Application --------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
